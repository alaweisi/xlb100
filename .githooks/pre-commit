#!/bin/sh
set -eu

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -File scripts/check-lean-risk.ps1 -DiffMode Staged
fi

if command -v powershell.exe >/dev/null 2>&1; then
  exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-lean-risk.ps1 -DiffMode Staged
fi

echo "XLB pre-commit: PowerShell is required to classify sensitive paths." >&2
exit 1
