NODE_ENV=staging
BACKEND_PORT=3000

# Demo-only background processors. Keep disabled unless staging is explicitly used for a controlled demo.
AUTO_RUN_ENABLED=false
AUTO_RUN_INTERVAL_MS=8000
AUTO_RUN_CITY_CODES=hangzhou

MYSQL_HOST=mysql
MYSQL_PORT=3306
STAGING_MYSQL_PORT=3307
MYSQL_DATABASE=xlb_staging
MYSQL_USER=xlb
MYSQL_PASSWORD=change-me
REDIS_HOST=redis
REDIS_PORT=6379
STAGING_REDIS_PORT=6380
JWT_SECRET=change-me-in-production
JWT_ACTIVE_KID=primary
JWT_KEYS_JSON={"primary":"change-me-in-production"}
JWT_ISSUER=xlb-backend
JWT_AUDIENCE=xlb-apps
JWT_TTL_SECONDS=86400
AUTH_PHONE_HASH_SECRET=change-me-in-production
AUTH_OTP_PEPPER=change-me-in-production

AUTH_OTP_TTL_SECONDS=300
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_LOCK_SECONDS=900
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_DEBUG_CODE_ENABLED=false
