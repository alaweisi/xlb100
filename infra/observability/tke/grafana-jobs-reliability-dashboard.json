{
  "annotations": {"list": []},
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Heartbeat age",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"refId": "A", "expr": "max(xlb_job_worker_heartbeat_age_seconds{namespace=~\"$namespace\"})"}],
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 120}, {"color": "red", "value": 180}]}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Reliability snapshot age",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"refId": "A", "expr": "max(xlb_data_reliability_snapshot_age_seconds{namespace=~\"$namespace\"})"}],
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 120}, {"color": "red", "value": 180}]}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 0}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Reliability ready",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"refId": "A", "expr": "min(xlb_data_reliability_ready{namespace=~\"$namespace\"})"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DEGRADED", "color": "red"}, "1": {"text": "READY", "color": "green"}}}]}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 0}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Outbox rows by state",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"refId": "A", "expr": "sum by (city, status) (xlb_outbox_events{namespace=~\"$namespace\"})", "legendFormat": "{{city}} / {{status}}"}],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Dispatch stream length and consumer groups",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"refId": "A", "expr": "max by (city) (xlb_dispatch_stream_length{namespace=~\"$namespace\"})", "legendFormat": "entries / {{city}}"},
        {"refId": "B", "expr": "max by (city) (xlb_dispatch_stream_consumer_groups{namespace=~\"$namespace\"})", "legendFormat": "groups / {{city}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Backlog oldest eligible age",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"refId": "A", "expr": "max by (city) (xlb_outbox_oldest_eligible_age_seconds{namespace=~\"$namespace\"})", "legendFormat": "{{city}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Pending and retry outbox rows",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"refId": "A", "expr": "sum by (city, status) (xlb_outbox_events{namespace=~\"$namespace\",status=~\"pending|retry_wait\"})", "legendFormat": "{{city}} / {{status}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Reliability exceptions",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"refId": "A", "expr": "max by (city) (xlb_outbox_expired_processing_leases{namespace=~\"$namespace\"})", "legendFormat": "expired leases / {{city}}"},
        {"refId": "B", "expr": "max by (city) (xlb_outbox_stalled_transactional_events{namespace=~\"$namespace\"})", "legendFormat": "stalled / {{city}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 21}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["xlb", "tke", "jobs", "reliability"],
  "templating": {"list": [
    {"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "query": "prometheus", "current": {}},
    {"name": "namespace", "label": "Namespace", "type": "query", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "query": {"query": "label_values(xlb_job_worker_heartbeat_age_seconds, namespace)", "refId": "StandardVariableQuery"}, "refresh": 1, "includeAll": true, "allValue": ".*", "multi": true, "current": {}}
  ]},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "XLB TKE jobs and data reliability",
  "uid": "xlb-tke-jobs-reliability",
