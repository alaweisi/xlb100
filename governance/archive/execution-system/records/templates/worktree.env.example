# Materialize this template only as `.env.worktree.local` inside the Work Unit.
# The launcher must populate it from the approved Work Unit Manifest. This file
# is documentation, never an independent slot-allocation source.

XLB_TRAIN_ID=replace-from-manifest
XLB_WORK_UNIT_ID=replace-from-manifest
WORKTREE_SLOT=1
COMPOSE_PROJECT_NAME=replace-from-manifest
XLB_ENVIRONMENT_LEASE_ID=replace-from-manifest-lease-ref
# SHA-256 of: GIT_BLOB_OID_SHA256_V1\nblobOid=<canonical-manifest-git-blob-oid>
XLB_MANIFEST_DIGEST=replace-with-typed-git-blob-oid-digest
XLB_BASE_COMMIT=replace-from-manifest
XLB_RUN_NONCE=replace-with-new-nonce-for-each-runtime-start

# Runtime authorization labels. These are derived from the frozen candidate
# and approved local Docker binding by the Runtime Canary launcher only;
# operators must never hand-fill them as an authorization signal.
XLB_RUNTIME_CANDIDATE_COMMIT=replace-from-approved-runtime-closure
XLB_RUNTIME_HEAD_COMMIT=replace-from-frozen-run-head
XLB_RUNTIME_INPUT_DIGEST=replace-with-frozen-input-digest
XLB_DOCKER_ENGINE_ID=replace-from-approved-local-engine
XLB_DOCKER_BINDING_DIGEST=replace-with-approved-binding-digest

# All ports come from the manifest and its active PORT lease.
WORKTREE_MYSQL_HOST_PORT=replace-from-manifest
WORKTREE_REDIS_HOST_PORT=replace-from-manifest
BACKEND_PORT=replace-from-manifest
CUSTOMER_PORT=replace-from-manifest
WORKER_PORT=replace-from-manifest
ADMIN_PORT=replace-from-manifest

MYSQL_HOST=127.0.0.1
MYSQL_PORT=replace-from-manifest
MYSQL_DATABASE=replace-from-manifest
MYSQL_USER=xlb
MYSQL_PASSWORD=replace-with-work-unit-local-password
MYSQL_ROOT_PASSWORD=replace-with-work-unit-local-root-password

# A separate Redis container is used for every Work Unit. Runtime DB-index or
# key-prefix sharing is intentionally not used as an isolation boundary.
REDIS_HOST=127.0.0.1
REDIS_PORT=replace-from-manifest
