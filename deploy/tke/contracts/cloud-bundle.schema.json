{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://xlb.local/schemas/tke/cloud-bundle.schema.json",
  "title": "XLB reviewed cloud environment bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "environment",
    "region",
    "accountId",
    "approvedKubeContext",
    "network",
    "files",
    "secretReferences",
    "costReview",
    "bundleSha256"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "environment": { "enum": ["staging", "production"] },
    "region": { "type": "string", "pattern": "^[a-z]{2}-[a-z]+(?:-[0-9]+)?$" },
    "accountId": { "type": "string", "pattern": "^[0-9]{6,20}$" },
    "approvedKubeContext": { "type": "string", "minLength": 3, "maxLength": 253 },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vpcId", "subnetIds"],
      "properties": {
        "vpcId": { "type": "string", "pattern": "^vpc-[a-zA-Z0-9]+$" },
        "subnetIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^subnet-[a-zA-Z0-9]+$" }
        }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["terraformVarFile", "backendConfig", "valuesFile", "imageLockFile"],
      "properties": {
        "terraformVarFile": { "$ref": "#/definitions/artifactPath" },
        "backendConfig": { "$ref": "#/definitions/artifactPath" },
        "valuesFile": { "$ref": "#/definitions/artifactPath" },
        "imageLockFile": { "$ref": "#/definitions/artifactPath" }
      }
    },
    "secretReferences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtimeSecretName", "tlsSecretName"],
      "properties": {
        "runtimeSecretName": { "$ref": "#/definitions/kubernetesName" },
        "tlsSecretName": { "$ref": "#/definitions/kubernetesName" }
      }
    },
    "costReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "monthlyMin", "monthlyMax", "sourceUrl", "reviewedAt", "owner"],
      "properties": {
        "currency": { "const": "CNY" },
        "monthlyMin": { "type": "number", "minimum": 0 },
        "monthlyMax": { "type": "number", "exclusiveMinimum": 0 },
        "sourceUrl": { "type": "string", "pattern": "^https://" },
        "reviewedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "owner": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "bundleSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "definitions": {
    "artifactPath": {
      "type": "string",
      "pattern": "^\\.artifacts/tke/[a-z0-9./-]+$"
    },
    "kubernetesName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253,
      "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
    }
  }
}
