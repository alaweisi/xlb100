{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "global",
    "serviceAccount",
    "runtimeSecrets",
    "backend",
    "jobs",
    "frontends",
    "config",
    "ingress",
    "migration"
  ],
  "properties": {
    "global": {
      "type": "object",
      "required": ["environment"],
      "properties": {
        "environment": { "enum": ["local", "staging", "production"] }
      }
    },
    "serviceAccount": {
      "type": "object",
      "required": ["create", "name"],
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "create": { "const": false } } },
          "then": { "properties": { "name": { "minLength": 1 } } }
        }
      ]
    },
    "runtimeSecrets": {
      "type": "object",
      "required": ["existingSecret"],
      "properties": {
        "existingSecret": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        }
      }
    },
    "backend": { "$ref": "#/definitions/workload" },
    "jobs": { "$ref": "#/definitions/jobsWorkload" },
    "frontends": {
      "type": "object",
      "required": ["customer", "worker", "admin"],
      "properties": {
        "customer": { "$ref": "#/definitions/workload" },
        "worker": { "$ref": "#/definitions/workload" },
        "admin": { "$ref": "#/definitions/workload" }
      }
    },
    "config": {
      "type": "object",
      "required": [
        "nodeEnv",
        "mysql",
        "redis",
        "rateLimitBackend",
        "trustProxyHops",
        "jwt",
        "auth",
        "jobs",
        "objectStorage"
      ],
      "properties": {
        "nodeEnv": { "type": "string", "minLength": 1 },
        "mysql": { "$ref": "#/definitions/mysqlEndpoint" },
        "redis": { "$ref": "#/definitions/redisEndpoint" },
        "rateLimitBackend": { "enum": ["memory", "redis"] },
        "trustProxyHops": { "type": "integer", "minimum": 0, "maximum": 10 },
        "objectStorage": {
          "type": "object",
          "required": ["provider", "localRoot", "cos"],
          "properties": {
            "provider": { "enum": ["local", "mock", "cos"] },
            "localRoot": { "type": "string" },
            "cos": {
              "type": "object",
              "required": ["bucket", "region"],
              "properties": {
                "bucket": { "type": "string" },
                "region": { "type": "string" }
              }
            }
          },
          "allOf": [
            {
              "if": { "properties": { "provider": { "const": "cos" } } },
              "then": {
                "properties": {
                  "cos": {
                    "properties": {
                      "bucket": { "minLength": 3 },
                      "region": { "pattern": "^[a-z]+-[a-z]+(-[a-z]+)?$" }
                    }
                  }
                }
              }
            }
          ]
        }
      }
    },
    "ingress": {
      "type": "object",
      "required": ["enabled", "className", "tls", "hosts"],
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string", "minLength": 1 },
        "tls": {
          "type": "object",
          "required": ["enabled", "secretName"],
          "properties": {
            "enabled": { "type": "boolean" },
            "secretName": { "type": "string" }
          },
          "allOf": [
            {
              "if": { "properties": { "enabled": { "const": true } } },
              "then": { "properties": { "secretName": { "minLength": 1 } } }
            }
          ]
        },
        "hosts": {
          "type": "object",
          "required": ["api", "customer", "worker", "admin"],
          "properties": {
            "api": { "$ref": "#/definitions/hostname" },
            "customer": { "$ref": "#/definitions/hostname" },
            "worker": { "$ref": "#/definitions/hostname" },
            "admin": { "$ref": "#/definitions/hostname" }
          }
        }
      }
    },
    "migration": {
      "type": "object",
      "required": ["enabled", "runId", "backoffLimit", "activeDeadlineSeconds", "ttlSecondsAfterFinished"],
      "properties": {
        "enabled": { "type": "boolean" },
        "runId": {
          "type": "string",
          "pattern": "^$|^[a-z0-9]([a-z0-9-]{0,38}[a-z0-9])?$"
        },
        "backoffLimit": { "type": "integer", "minimum": 0, "maximum": 3 },
        "activeDeadlineSeconds": { "type": "integer", "minimum": 60, "maximum": 3600 },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 300 }
      },
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } } },
          "then": { "properties": { "runId": { "minLength": 1 } } }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "global": {
            "properties": { "environment": { "enum": ["staging", "production"] } }
          }
        }
      },
      "then": {
        "properties": {
          "backend": {
            "properties": { "image": { "properties": { "digest": { "$ref": "#/definitions/digest" } } } }
          },
          "frontends": {
            "properties": {
              "customer": { "properties": { "image": { "properties": { "digest": { "$ref": "#/definitions/digest" } } } } },
              "worker": { "properties": { "image": { "properties": { "digest": { "$ref": "#/definitions/digest" } } } } },
              "admin": { "properties": { "image": { "properties": { "digest": { "$ref": "#/definitions/digest" } } } } }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "global": { "properties": { "environment": { "const": "production" } } }
        }
      },
      "then": {
        "properties": {
          "backend": { "properties": { "replicaCount": { "minimum": 2 } } },
          "jobs": { "properties": { "replicaCount": { "const": 1 } } },
          "frontends": {
            "properties": {
              "customer": { "properties": { "replicaCount": { "minimum": 2 } } },
              "worker": { "properties": { "replicaCount": { "minimum": 2 } } },
              "admin": { "properties": { "replicaCount": { "minimum": 2 } } }
            }
          },
          "config": {
            "properties": {
              "nodeEnv": { "const": "production" },
              "rateLimitBackend": { "const": "redis" },
              "trustProxyHops": { "minimum": 1 },
              "mysql": { "properties": { "tlsEnabled": { "const": true } } },
              "redis": { "properties": { "tlsEnabled": { "const": true } } },
              "objectStorage": { "properties": { "provider": { "const": "cos" } } }
            }
          },
          "ingress": {
            "properties": {
              "enabled": { "const": true },
              "tls": { "properties": { "enabled": { "const": true } } }
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag", "digest", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "digest": { "type": "string", "pattern": "^$|^sha256:[a-fA-F0-9]{64}$" },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "jobsImage": {
      "type": "object",
      "required": ["repository", "tag", "digest", "pullPolicy"],
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "digest": { "type": "string", "pattern": "^$|^sha256:[a-fA-F0-9]{64}$" },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "resources": {
      "type": "object",
      "required": ["requests", "limits"],
      "properties": {
        "requests": {
          "type": "object",
          "required": ["cpu", "memory"]
        },
        "limits": {
          "type": "object",
          "required": ["cpu", "memory"]
        }
      }
    },
    "workload": {
      "type": "object",
      "required": ["replicaCount", "image", "resources"],
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": { "$ref": "#/definitions/image" },
        "resources": { "$ref": "#/definitions/resources" }
      }
    },
    "jobsWorkload": {
      "type": "object",
      "required": ["replicaCount", "image", "resources"],
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": { "$ref": "#/definitions/jobsImage" },
        "resources": { "$ref": "#/definitions/resources" }
      }
    },
    "mysqlEndpoint": {
      "type": "object",
      "required": ["host", "port", "database", "user", "tlsEnabled"],
      "properties": {
        "host": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "database": { "type": "string", "minLength": 1 },
        "user": { "type": "string", "minLength": 1 },
        "tlsEnabled": { "type": "boolean" }
      }
    },
    "redisEndpoint": {
      "type": "object",
      "required": ["host", "port", "tlsEnabled"],
      "properties": {
        "host": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "tlsEnabled": { "type": "boolean" }
      }
    },
    "hostname": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[A-Za-z0-9]([A-Za-z0-9.-]*[A-Za-z0-9])?$"
    }
  }
}
