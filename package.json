{
  "name": "xlb",
  "version": "0.0.0",
  "private": true,
  "description": "喜乐帮 / XLB — 三端 App Monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "node scripts/run-vitest-projects.mjs",
