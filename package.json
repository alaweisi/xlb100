{
  "name": "xlb",
  "version": "0.0.0",
  "private": true,
  "description": "喜乐帮 / XLB — 三端 App Monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "node scripts/run-vitest-projects.mjs",
    "test:e2e:phase21": "playwright test tests/e2e/phase21-three-app-smoke.spec.ts",
    "test:e2e:phase22": "vitest run --workspace vitest.workspace.ts --project db-serial tests/integration/phase22CrossPhaseE2E.test.ts && playwright test tests/e2e/phase21-three-app-smoke.spec.ts",
    "test:security:phase22": "vitest run --workspace vitest.workspace.ts --project db-serial tests/security/phase22AuthorizationMatrix.test.ts",
    "test:performance:phase22": "vitest run --workspace vitest.workspace.ts --project performance-serial",
    "test:observability:phase22": "vitest run --workspace vitest.workspace.ts --project unit-contract tests/unit/phase22Observability.test.ts",
    "test:coverage:phase22": "node scripts/run-phase22-coverage.mjs",
    "test:ci-fail-closed": "node scripts/check-phase22-ci-fail-closed.mjs",
    "audit:critical": "pnpm audit --audit-level critical",
    "gate:phase22": "node scripts/run-phase22-gates.mjs",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "lint": "turbo run lint",
    "preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/preflight-architecture.ps1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.53.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "3.2.6",
    "cross-env": "7.0.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
