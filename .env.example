NODE_ENV=development
BACKEND_PORT=3000

# Demo-only background processors. Keep disabled unless running a local demo.
AUTO_RUN_ENABLED=false
AUTO_RUN_INTERVAL_MS=8000
AUTO_RUN_CITY_CODES=hangzhou

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=xlb_local
MYSQL_USER=xlb
MYSQL_PASSWORD=xlb_local_password
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
JWT_SECRET=change-me-in-production
JWT_ACTIVE_KID=primary
JWT_KEYS_JSON={"primary":"change-me-in-production"}
JWT_ISSUER=xlb-backend
JWT_AUDIENCE=xlb-apps
JWT_TTL_SECONDS=86400
AUTH_PHONE_HASH_SECRET=xlb-local-phone-hash-secret-change-before-production
AUTH_OTP_PEPPER=xlb-local-otp-pepper-change-before-production

# Local/dev OTP verification code support. Debug readback is disabled in production.
AUTH_OTP_TTL_SECONDS=300
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_LOCK_SECONDS=900
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_DEBUG_CODE_ENABLED=true
