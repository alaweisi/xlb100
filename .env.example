NODE_ENV=development
BACKEND_PORT=3000

# Demo-only background processors. Keep disabled unless running a local demo.
AUTO_RUN_ENABLED=false
AUTO_RUN_INTERVAL_MS=8000
AUTO_RUN_CITY_CODES=hangzhou

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=xlb_local
MYSQL_USER=xlb
MYSQL_PASSWORD=xlb_local_password
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
JWT_SECRET=change-me-in-production

# Local/dev OTP verification code support. Debug readback is disabled in production.
AUTH_OTP_TTL_SECONDS=300
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_DEBUG_CODE_ENABLED=true
