# Production configuration template. Placeholder values intentionally fail the
# deployment preflight until real infrastructure and secret-manager files exist.
# Any real production operation still requires one explicit Human confirmation; no Queue or governance state machine is used.
# Copy to .env.production only after Security/Ops supplies real production values.
# Do not use this file as production evidence.

NODE_ENV=production
BACKEND_PORT=3000

# Safety guard: production must not enable demo auto-run processors by default.
AUTO_RUN_ENABLED=false
AUTO_RUN_INTERVAL_MS=8000
AUTO_RUN_CITY_CODES=hangzhou

# External production MySQL. Do not point this at staging.
MYSQL_HOST=prod-mysql.example.invalid
MYSQL_PORT=3306
MYSQL_DATABASE=xlb_prod_placeholder
MYSQL_USER=xlb_prod_app_placeholder
MYSQL_PASSWORD_SECRET_FILE=/run/xlb-secrets/mysql_password
MYSQL_TLS_CA_SECRET_FILE=/run/xlb-secrets/mysql_tls_ca.pem

# External production Redis. Do not point this at staging.
REDIS_HOST=prod-redis.example.invalid
REDIS_PORT=6379
REDIS_PASSWORD_SECRET_FILE=/run/xlb-secrets/redis_password
REDIS_TLS_CA_SECRET_FILE=/run/xlb-secrets/redis_tls_ca.pem

# Secret-manager value required before production activation.
JWT_SECRET_FILE=/run/xlb-secrets/jwt_secret
JWT_ACTIVE_KID=primary
JWT_KEYS_JSON_SECRET_FILE=/run/xlb-secrets/jwt_keys.json
JWT_ISSUER=xlb-backend
JWT_AUDIENCE=xlb-apps
JWT_TTL_SECONDS=86400
AUTH_PHONE_HASH_SECRET_FILE=/run/xlb-secrets/auth_phone_hash_secret
AUTH_OTP_PEPPER_SECRET_FILE=/run/xlb-secrets/auth_otp_pepper

# OTP verification codes are one-time Redis records.
# Production MUST keep debug code readback disabled; real SMS delivery remains a future investor-approved TODO.
AUTH_OTP_TTL_SECONDS=300
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_LOCK_SECONDS=900
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_DEBUG_CODE_ENABLED=false

# Canonical production edge. The three apps use same-origin /api and WSS;
# do not set a cross-origin VITE_API_BASE for production images.
XLB_DOMAIN=example.invalid
PROD_HTTP_BIND_ADDRESS=0.0.0.0
PROD_HTTPS_BIND_ADDRESS=0.0.0.0
TLS_FULLCHAIN_SECRET_FILE=/run/xlb-secrets/tls_fullchain.pem
TLS_PRIVATE_KEY_SECRET_FILE=/run/xlb-secrets/tls_private_key.pem

# Production smoke URLs. These must be real HTTPS production hostnames before use.
PROD_BACKEND_HEALTH_URL=https://api.example.invalid/health
PROD_BACKEND_DB_HEALTH_URL=https://api.example.invalid/api/system/db-health
PROD_CUSTOMER_URL=https://customer.example.invalid/
PROD_WORKER_URL=https://worker.example.invalid/
PROD_ADMIN_URL=https://admin.example.invalid/

# Read-only production business smoke identity. The token must belong to a
# dedicated Customer smoke account, the SKU must be active in the selected
# city, and the order must already exist and belong to that account.
PROD_SMOKE_CITY_CODE=hangzhou
PROD_SMOKE_SKU_ID=REPLACE_WITH_ACTIVE_SMOKE_SKU
PROD_SMOKE_ORDER_ID=REPLACE_WITH_EXISTING_SMOKE_ORDER
PROD_SMOKE_CUSTOMER_TOKEN_FILE=/run/xlb-secrets/smoke_customer_token

# Required immutable registry digests. Tags are rejected by deploy preflight.
PROD_BACKEND_IMAGE=registry.example.invalid/xlb/backend@sha256:REPLACE_WITH_64_HEX_DIGEST
PROD_GATEWAY_IMAGE=registry.example.invalid/xlb/nginx@sha256:REPLACE_WITH_64_HEX_DIGEST
PROD_CUSTOMER_IMAGE=registry.example.invalid/xlb/customer@sha256:REPLACE_WITH_64_HEX_DIGEST
PROD_WORKER_IMAGE=registry.example.invalid/xlb/worker@sha256:REPLACE_WITH_64_HEX_DIGEST
PROD_ADMIN_IMAGE=registry.example.invalid/xlb/admin@sha256:REPLACE_WITH_64_HEX_DIGEST
