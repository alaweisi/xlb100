# Phase 14 production placeholder environment.
# Copy to .env.production only after Security/Ops supplies real production values.
# Do not use this file as production evidence.

NODE_ENV=production
BACKEND_PORT=3000

# External production MySQL. Do not point this at staging.
MYSQL_HOST=prod-mysql.example.invalid
MYSQL_PORT=3306
MYSQL_DATABASE=xlb_prod_placeholder
MYSQL_USER=xlb_prod_app_placeholder
MYSQL_PASSWORD=REPLACE_WITH_SECRET_MANAGER_VALUE

# External production Redis. Do not point this at staging.
REDIS_HOST=prod-redis.example.invalid
REDIS_PORT=6379

# Secret-manager value required before production activation.
JWT_SECRET=REPLACE_WITH_SECRET_MANAGER_VALUE

# Production smoke URLs. These must be real HTTPS production hostnames before use.
PROD_BACKEND_HEALTH_URL=https://api.example.invalid/health
PROD_BACKEND_DB_HEALTH_URL=https://api.example.invalid/api/system/db-health
PROD_CUSTOMER_URL=https://customer.example.invalid/
PROD_WORKER_URL=https://worker.example.invalid/
PROD_ADMIN_URL=https://admin.example.invalid/

# Optional image names for registry-based production deploys.
PROD_BACKEND_IMAGE=xlb/backend:phase14-placeholder
PROD_CUSTOMER_IMAGE=xlb/customer:phase14-placeholder
PROD_WORKER_IMAGE=xlb/worker:phase14-placeholder
PROD_ADMIN_IMAGE=xlb/admin:phase14-placeholder
